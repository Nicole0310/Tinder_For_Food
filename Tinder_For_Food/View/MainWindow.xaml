<Window x:Class="Tinder_For_Food.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tinder_For_Food"
        mc:Ignorable="d"
        Title="Tinder-4-Food" Height="700" Width="500" Background="#FAFAFA">
    <ScrollViewer>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10">
            <Image x:Name="MealImage"
               Width="400"
               Height="220"
               Stretch="Uniform"
               Margin="0,10"
               SnapsToDevicePixels="True"
               ClipToBounds="True"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
            />
            
            
            <TextBlock x:Name="MealName" TextAlignment="Center" FontWeight="Bold" FontSize="20" Margin="0,10"/>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock x:Name="CaloriesText" FontSize="14"/>
                <TextBlock x:Name="ProteinText" FontSize="14"/>
                <TextBlock x:Name="CarbohydratesText" FontSize="14"/>
                <TextBlock x:Name="FatsText" FontSize="14"/>
            </StackPanel>

            <ItemsControl x:Name="IngredientsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="• " FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding}" FontSize="14"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <Button x:Name="DislikeButton" Content="❌ Dislike" Width="100" Height="40" Margin="5" Background="#FF6B6B" Foreground="White" Click="DislikeButton_Click"/>
                <Button x:Name="LikeButton" Content="👍Like" Width="100" Height="40" Margin="5" Background="#4CAF50" Foreground="White" Click="LikeButton_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
